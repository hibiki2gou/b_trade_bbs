<%# 募集の投稿フォーム。
    locals: post, wanted_options（欲しいカード候補）, offered_options（出せるカード候補）,
            cancel_path（キャンセル時の戻り先） %>
<%= form_with model: post, url: posts_path, method: :post, class: "post-form" do |f| %>
  <div class="field">
    <%= f.label :wanted_card_id, "欲しいカード" %>
    <%= f.collection_select :wanted_card_id, wanted_options, :id, :picker_label,
          { prompt: "カードを選んでください" }, { class: "input" } %>
  </div>

  <div class="field">
    <%= f.label :offered_card_ids, "出せるカード（複数選べます・Ctrl/⌘ を押しながらクリック）" %>
    <%= f.collection_select :offered_card_ids, offered_options, :id, :picker_label,
          {}, { multiple: true, size: 6, class: "input input--multi" } %>
    <p class="field__hint">出せるカードが無ければ選ばなくてもOK（備考で「交渉」と書けます）。</p>
  </div>

  <div class="field">
    <%= f.label :note, "備考" %>
    <%= f.text_area :note, rows: 3, class: "input",
          placeholder: "よろしくお願いします / 希望する交換方法 など" %>
  </div>

  <div class="field">
    <%= f.label :nickname, "ニックネーム" %>
    <%= f.text_field :nickname, class: "input", placeholder: "お名前（ニックネーム）" %>
  </div>

  <div class="form-actions">
    <%= f.submit "投稿する", class: "btn btn--primary" %>
    <%= link_to "キャンセル", cancel_path, class: "btn btn--ghost" %>
  </div>
<% end %>
