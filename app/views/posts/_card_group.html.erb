<%# 募集の「欲しい」「出せる」のカードを表示する共通部品。
    レア度ごとに区切り、その中はクラブの並び順（→背番号）で並べる。
    locals: cards（Card の配列）, empty_text（0枚のときに出す文言） %>
<% if cards.empty? %>
  <span class="muted"><%= empty_text %></span>
<% else %>
  <div class="cardgroup">
    <%# レア度の高い順にまとめ、同じレア度の中はクラブ順→背番号順 %>
    <% cards.group_by(&:rarity).sort_by { |rarity, _| -rarity }.each do |rarity, group| %>
      <div class="cardgroup__row">
        <span class="cardgroup__rarity"><%= "★" * rarity %></span>
        <span class="cardgroup__items">
          <% group.sort_by { |c| [ c.team.position, c.sort_number ] }.each do |c| %>
            <span class="cardchip">
              <span class="cardchip__player"><%= c.label %></span>
              <span class="cardchip__team"><%= c.team.name %></span>
              <span class="cardchip__set"><%= c.topic.name %></span>
            </span>
          <% end %>
        </span>
      </div>
    <% end %>
  </div>
<% end %>
