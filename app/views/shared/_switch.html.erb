<%# 「弾で見る / チームで見る / カードを探す」の切り替えボタン。
    locals: active（:topics か :teams か :cards） %>
<nav class="switch">
  <% [
       [ :topics, "弾で見る",     topics_path ],
       [ :teams,  "チームで見る", teams_path  ],
       [ :cards,  "カードを探す", cards_path  ]
     ].each do |key, label, path| %>
    <% if active == key %>
      <span class="switch__btn switch__btn--active"><%= label %></span>
    <% else %>
      <%= link_to label, path, class: "switch__btn" %>
    <% end %>
  <% end %>
</nav>
