<%# 弾/チームの掲示板の共通レイアウト。topics/show と teams/show から呼ばれる。
    locals:
      record            … Topic か Team
      posts             … 表示する募集
      post              … 新規投稿フォーム用の空 Post
      wanted_options    … 欲しいカードの選択肢
      offered_options   … 出せるカードの選択肢
      showing_completed … 成立済みを表示中か（true/false）
      open_path         … 「募集中」タブのリンク先
      completed_path    … 「成立済み」タブのリンク先
      index_path        … 「一覧へもどる」のリンク先（弾一覧 or チーム一覧）
      cards             … この弾/チームの収録カード（一覧表示用）
      card_context      … カード一覧の右に何を出すか
                          :team  … チーム名（弾の掲示板。チーム順に並ぶので目印になる）
                          :topic … 弾名（チームの掲示板。弾をまたぐため） %>

<%# ブラウザの「戻る」(:back)ではなく、一覧ページへ確実に飛ぶ。
    投稿後は履歴が増えていて :back では一覧まで戻れないため。 %>
<p class="back"><%= link_to "← 一覧へもどる", index_path %></p>

<%# 弾/チームの見出しは画面上部に貼り付ける（sticky）。
    スクロールしても「今どの弾を見ているか」が分かるようにするため。
    2つのボタンもこの中に並べ、押すとそれぞれモーダルが開く。 %>
<div class="board-header board-header--sticky">
  <div class="board-header__thumb"><%= board_thumbnail(record) %></div>
  <div class="board-header__text">
    <h1><%= record.name %></h1>
    <% if record.respond_to?(:description) && record.description.present? %>
      <p class="board-header__desc"><%= record.description %></p>
    <% end %>
  </div>

  <div class="board-header__actions">
    <%# --- 収録カード一覧のモーダル --- %>
    <% if cards.any? %>
      <div data-controller="modal">
        <button type="button" class="btn btn--small"
                data-action="modal#open">収録カード一覧（<%= cards.size %>）</button>

        <dialog class="modal" data-modal-target="dialog"
                data-action="click->modal#closeOnBackdrop">
          <div class="modal__head">
            <h2 class="modal__title"><%= record.name %> の収録カード（<%= cards.size %>枚）</h2>
            <button type="button" class="modal__close"
                    data-action="modal#close" aria-label="閉じる">✕</button>
          </div>
          <div class="modal__body">
            <ul class="cardlist__items">
              <% cards.each do |c| %>
                <li class="cardlist__item">
                  <span class="cardlist__name"><%= c.label %></span>
                  <span class="stars"><%= c.stars %></span>
                  <span class="cardlist__meta">
                    <%= card_context == :team ? c.team.name : c.topic.name %>
                  </span>
                </li>
              <% end %>
            </ul>
          </div>
        </dialog>
      </div>
    <% end %>

    <%# --- 募集フォームのモーダル。投稿に失敗したときは開いた状態で再表示する --- %>
    <% unless showing_completed %>
      <div data-controller="modal"
           data-modal-open-value="<%= post.errors.any? %>">
        <button type="button" class="btn btn--small btn--primary"
                data-action="modal#open">＋ 新しく募集する</button>

        <dialog class="modal" data-modal-target="dialog"
                data-action="click->modal#closeOnBackdrop">
          <div class="modal__head">
            <h2 class="modal__title"><%= record.name %> で募集する</h2>
            <button type="button" class="modal__close"
                    data-action="modal#close" aria-label="閉じる">✕</button>
          </div>
          <div class="modal__body">
            <%= render "posts/form", post: post, wanted_options: wanted_options,
                                     offered_options: offered_options,
                                     cancel_path: open_path,
                                     board_type: record.model_name.param_key,
                                     board_id: record.id %>
          </div>
        </dialog>
      </div>
    <% end %>
  </div>
</div>

<nav class="tabs">
  <%= link_to "募集中", open_path,
        class: "tabs__item #{'tabs__item--active' unless showing_completed}" %>
  <%= link_to "成立済み", completed_path,
        class: "tabs__item #{'tabs__item--active' if showing_completed}" %>
</nav>

<% if posts.any? %>
  <ul class="posts">
    <%= render partial: "posts/post", collection: posts, as: :post %>
  </ul>
<% else %>
  <p class="empty">
    <%= showing_completed ? "成立したトレードはまだありません。" : "まだ募集がありません。最初の募集をしてみましょう。" %>
  </p>
<% end %>
