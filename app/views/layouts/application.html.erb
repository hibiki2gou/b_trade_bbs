<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "TRADE COURT" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="App">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <header class="site-header">
      <div class="container site-header__inner">
        <%# ロゴにサイト名と説明の両方が入っているので、テキストは添えない。
            画像が用意できていない間はテキストで代替する。 %>
        <%= link_to root_path, class: "site-header__logo" do %>
          <%= board_thumbnail_logo %>
        <% end %>
      </div>
    </header>

    <%# 通知は画面右上にトーストとして出す（ページの流れを崩さないため）。
        数秒で自動的に消える（toast Stimulus コントローラ）。 %>
    <% if notice.present? || alert.present? %>
      <div class="toasts" data-controller="toast">
        <% if notice.present? %>
          <div class="toast toast--notice"><%= notice %></div>
        <% end %>
        <% if alert.present? %>
          <div class="toast toast--alert"><%= alert %></div>
        <% end %>
      </div>
    <% end %>

    <main class="container">
      <%= yield %>
    </main>

    <footer class="site-footer">
      <div class="container">
        <p>TRADE COURT — Bリーグカードのトレード相手を見つける掲示板</p>
      </div>
    </footer>
  </body>
</html>
